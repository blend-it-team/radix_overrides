{#
/**
 * @file
 * Template for the main page.
 */
#}
{% set page_attributes = attributes ?: create_attribute() %}
{% set 
  page_classes = [
    'layout-main',
    'd-lg-grid',
  ]|merge(page_utility_classes ?: []) 
%}

<main {{ page_attributes.addClass(page_classes) }}>
  {% block page_header %}
    {% if page.header %}
      <div class="layout-header">
        <div class="d-flex justify-content-between align-items-center">
          <div class="d-lg-none px-4">
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar-offcanvas" aria-controls="sidebar-offcanvas" aria-expanded="false" aria-label="Toggle navigation">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
              </svg>
            </button>
          </div>
          {{ page.header}}
          <div class="d-lg-none px-4">
          </div>
        </div>
      </div>
    {% endif %}
  {% endblock %}

  {% block page_header_expanded %}
    {% if page.header_expanded %}
      <div class="layout-header-expanded align-items-center d-none d-lg-flex">
        <div class="navbar navbar-expand-lg w-100">
          <div class="container-fluid">
            {{ page.header_expanded }}
          </div>
        </div>
      </div>
    {% endif %}
  {% endblock %}

  {% block page_sidebar %}
    {% if page.sidebar %}
      <aside class="layout-sidebar fixed d-lg-flex text-bg-primary" id="sidebar">
        {{ page.sidebar }}
        <div class="sidebar-footer">
            {{ page.sidebar_footer }}
        </div>
      </aside>
    {% endif %}
  {% endblock %}

  {% block page_content %}
    <div class="layout-main-content" id="content">
      <div class="container-fluid py-4 p-lg-4">
        {{ page.content }}
      </div>
    </div>
  {% endblock %}
</main>
{% block page_sidebar_offcanvas %}
  <aside class="offcanvas offcanvas-lg offcanvas-start" id="sidebar-offcanvas">
    <div class="offcanvas-header">
      <button type="button" class="btn-close ms-0 mt-1" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body flex-grow-1">
      {{ page.header_expanded }}
      {{ page.sidebar }}
    </div>
    <div class="sidebar-footer">
      {{ page.sidebar_footer }}
    </div>
  </aside>
{% endblock %}
