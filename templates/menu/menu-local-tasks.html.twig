{#
/**
 * @file
 * Default theme implementation to display primary and secondary local tasks.
 *
 * Available variables:
 * - primary: HTML list items representing primary tasks.
 * - secondary: HTML list items representing primary tasks.
 *
 * Each item in these variables (primary and secondary) can be individually
 * themed in menu-local-task.html.twig.
 *
 * @ingroup templates
 *
 * @see template_preprocess_menu_local_tasks()
 */
#}
{% if primary %}

  <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
  {% include 'radix_overrides:local-tasks-nav' with {
    nav_utility_classes : [
      'tabs--primary nav tabs-box bg-body-secondary active-state hover-opacity fw-bold gap-1 d-md-inline-flex rounded-3 mb-3 p-1'
    ],
    content: primary
  }%}
{% endif %}
{# reset nav_utility_classes #}
{% set nav_utility_classes = [] %}
{% if secondary %}
  <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
  {{ include ('radix_overrides:local-tasks-nav', {
    nav_utility_classes : [
      'tabs--secondary nav nav-tabs'
    ],
    content: secondary
  }, with_context =  false)
  }}
{% endif %}
